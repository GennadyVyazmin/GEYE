APP_HOST=0.0.0.0
APP_PORT=8000
RTSP_URL=rtsp://user:password@camera-ip:554/stream1
MODEL_PATH=yolov8n.pt
TRACKER_CONFIG_PATH=app/tracker_bytetrack.yaml
DETECTOR_CONF=0.35
DETECTOR_IOU=0.5
MIN_PERSON_BOX_HEIGHT_PX=60
MIN_PERSON_BOX_AREA_RATIO=0.012
FRAME_MAX_WIDTH=960
PROCESS_EVERY_N_FRAMES=2
JPEG_QUALITY=75
RTSP_LOW_LATENCY_MODE=true
RTSP_DRAIN_GRABS=3
MIN_DB_EVENT_INTERVAL_SEC=2.0
COUNT_CONFIRM_MIN_HITS=3
COUNT_CONFIRM_MIN_AGE_SEC=4.0
UNIQUE_REQUIRE_FACE_FOR_COUNT=true
FACE_CONFIRM_MIN_HITS=1
ONLINE_TTL_SEC=2.0
PHOTO_DIR=captures
PHOTO_CAPTURE_ONCE_PER_ID=false
PHOTO_UPDATE_INTERVAL_SEC=15.0
GALLERY_LIMIT=120
FACE_LOCK_MATCH_THRESHOLD=0.72
FACE_LOCK_MARGIN=0.05
FACE_MIN_SCORE=0.06
FACE_REBIND_MATCH_THRESHOLD=0.86
FACE_REBIND_MARGIN=0.08
FACE_PROFILES_REFRESH_SEC=8.0
FACE_PROFILE_BANK_PER_ID=6
FACE_REBIND_MIN_VOTES=2
FACE_REBIND_CLUSTER_DELTA=0.03
ENABLE_LINE_CROSSING=false
LINE_Y_RATIO=0.55
CROSSING_DEBOUNCE_SEC=2.0
REID_MATCH_THRESHOLD=0.68
REID_WEAK_MATCH_THRESHOLD=0.50
REID_WEAK_MARGIN=0.08
REID_WEAK_MATCH_RECENCY_SEC=120
REID_MAX_ABSENCE_SEC=86400
TRACK_TTL_SEC=15.0
